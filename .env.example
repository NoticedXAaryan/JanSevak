# ============================================
# JanSeva Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# --- Telegram ---
TELEGRAM_BOT_TOKEN=replace-with-your-botfather-token

# --- Database ---
POSTGRES_USER=janseva
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_DB=janseva
# Docker/Dokploy Compose uses service hostnames. For host-machine uv commands,
# change "postgres" to "localhost".
DATABASE_URL=postgresql+asyncpg://janseva:change-this-db-password@postgres:5432/janseva
DATABASE_URL_SYNC=postgresql://janseva:change-this-db-password@postgres:5432/janseva

# --- Redis ---
# Docker/Dokploy Compose uses service hostnames. For host-machine uv commands,
# change "redis" to "localhost".
REDIS_URL=redis://redis:6379/0

# --- LLM ---
# Option 1: Google Gemini (recommended for production)
GOOGLE_API_KEY=your-google-api-key-here
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=models/embedding-001

# Option 2: Ollama (for local development without API costs)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1
# OLLAMA_BASE_URL=http://localhost:11434

# Option 3: OpenRouter
# OPENROUTER_API_KEY=your-openrouter-api-key-here
# LLM_PROVIDER=openrouter
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Security ---
ADMIN_JWT_SECRET=change-this-to-a-random-64-char-string
REPORT_ENCRYPTION_KEY=change-this-to-a-fernet-key

# --- Admin ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-in-production

# --- Voice (optional for Phase 3) ---
# WHISPER_MODEL_SIZE=large-v3
# INDICWHISPER_MODEL_PATH=./models/indicwhisper
# GROQ_API_KEY=your-groq-api-key-here

# --- App ---
ENV=production
LOG_LEVEL=INFO
RUN_MIGRATIONS=true
SEED_KNOWLEDGE_BASE=true
